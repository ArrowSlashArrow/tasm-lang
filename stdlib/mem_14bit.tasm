; This file contains the standard implementation for the memory controller, which allows the programmer to dynamically access any counter/timer they wish to given any address.
; This program supports all addresses from 1 - 16384 inclusive, which covers all normal item IDs. Using this program to try to access counters higher than that range may lead to undefined behaviour.
; This file contains five exports:
; - `mem`; the routine that is used to access the address in memory.
; - `_std_mem_cread`, `_std_mem_cwrite`, `_std_mem_tread`, `_std_mem_twrite`; the four basic functions of this memory: reading/writing to a timer/counter
; - `_std_mem_end`; placeholder routine that is remapped to a function that will be called

; To use this program, paste the whole thing into your file. Combine the _init routines to ensure that your file can compile. 
; Many items here are internal to this file, but will be exposed when this file's contents are pasted. 
; To prevent name collisions, all such items are prefixed with `_std_mem_`. 

; ---- Aliases ----
; Paste these into your `_init` routine when using this file. These aliases are necessary for this file to work.
; The values of these aliases may be freely changed, so long as they are all unique. 
; 
; Each alias is documented below:
_init:
    ; Temporary counter used to evaluate the address stored in `ptrpos`.
    alias _std_mem_temp, C9997
    ; Stores the address that is going to be accessed.
    alias _std_mem_ptrpos, C9999
    ; Temporary counter for storing the result of reading from memory (if we are reading from a counter)
    alias _std_mem_cmemreg, C9998
    ; Temporary timer for storing the result of reading from memory (if we are reading from a timer)
    alias _std_mem_tmemreg, T9998

; `mem` should be called with this exact syntax always:
;   SPAWN mem   | ordered:false remap: {_std_mem_end: function}
; where `function` is one of the four memory functions provided: `cread`, `cwrite`, `tread`, `twrite`
; For example, to read a counter's value (cread), use the following:
;   SPAWN mem   | ordered:false remap: {_std_mem_end: _std_mem_cread}

mem:
    ; copy ptrpos to temporary mutable counter
    ; it is necessary to clone it as the algorithm mutates this
    MOV _std_mem_temp, _std_mem_ptrpos
    ifg bit_14_on, bit_13, _std_mem_temp, 8192    ; check bit 14

; all remap tables were generated by a script
bit_14_on:
    sub _std_mem_temp, 8192
    ; yes, you can access addresses past 9,999, but only through remaps. 
    spawn bit_13 | ordered:false delay:0.0 remap: {1:8193, 2:8194, 3:8195, 4:8196, 5:8197, 6:8198, 7:8199, 8:8200, 9:8201, 10:8202, 11:8203, 12:8204, 13:8205, 14:8206, 15:8207, 16:8208, 17:8209, 18:8210, 19:8211, 20:8212, 21:8213, 22:8214, 23:8215, 24:8216, 25:8217, 26:8218, 27:8219, 28:8220, 29:8221, 30:8222, 31:8223, 32:8224, 33:8225, 34:8226, 35:8227, 36:8228, 37:8229, 38:8230, 39:8231, 40:8232, 41:8233, 42:8234, 43:8235, 44:8236, 45:8237, 46:8238, 47:8239, 48:8240, 49:8241, 50:8242, 51:8243, 52:8244, 53:8245, 54:8246, 55:8247, 56:8248, 57:8249, 58:8250, 59:8251, 60:8252, 61:8253, 62:8254, 63:8255, 64:8256, 65:8257, 66:8258, 67:8259, 68:8260, 69:8261, 70:8262, 71:8263, 72:8264, 73:8265, 74:8266, 75:8267, 76:8268, 77:8269, 78:8270, 79:8271, 80:8272, 81:8273, 82:8274, 83:8275, 84:8276, 85:8277, 86:8278, 87:8279, 88:8280, 89:8281, 90:8282, 91:8283, 92:8284, 93:8285, 94:8286, 95:8287, 96:8288, 97:8289, 98:8290, 99:8291, 100:8292, 101:8293, 102:8294, 103:8295, 104:8296, 105:8297, 106:8298, 107:8299, 108:8300, 109:8301, 110:8302, 111:8303, 112:8304, 113:8305, 114:8306, 115:8307, 116:8308, 117:8309, 118:8310, 119:8311, 120:8312, 121:8313, 122:8314, 123:8315, 124:8316, 125:8317, 126:8318, 127:8319, 128:8320, 129:8321, 130:8322, 131:8323, 132:8324, 133:8325, 134:8326, 135:8327, 136:8328, 137:8329, 138:8330, 139:8331, 140:8332, 141:8333, 142:8334, 143:8335, 144:8336, 145:8337, 146:8338, 147:8339, 148:8340, 149:8341, 150:8342, 151:8343, 152:8344, 153:8345, 154:8346, 155:8347, 156:8348, 157:8349, 158:8350, 159:8351, 160:8352, 161:8353, 162:8354, 163:8355, 164:8356, 165:8357, 166:8358, 167:8359, 168:8360, 169:8361, 170:8362, 171:8363, 172:8364, 173:8365, 174:8366, 175:8367, 176:8368, 177:8369, 178:8370, 179:8371, 180:8372, 181:8373, 182:8374, 183:8375, 184:8376, 185:8377, 186:8378, 187:8379, 188:8380, 189:8381, 190:8382, 191:8383, 192:8384, 193:8385, 194:8386, 195:8387, 196:8388, 197:8389, 198:8390, 199:8391, 200:8392, 201:8393, 202:8394, 203:8395, 204:8396, 205:8397, 206:839