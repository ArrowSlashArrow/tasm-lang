bit_1:
    ifg bit_1_on, bit_1_off, _std_mem_temp, 1

bit_1_on:
    sub _std_mem_temp, 1
    spawn _std_mem_end   | ordered:false delay:0.0 remap: {8200:2}

bit_1_off:
    spawn _std_mem_end   | ordered:false delay:0.0 remap: {8200:1}

_std_mem_end:
    ; here, end is a placeholder as the id for `end` is remapped when mem is spawned. 
    ; this routine is optimized away so that it doesn't take up an extra group due to it having 0 instructions

; ---- memory functions ----
; 8200 is the id that is being remapped in the memory controller (above)
; it doesn't matter what this ID is, just so long as it matches the ids remapped in `bit_1_on` and `bit_1_off`
_std_mem_cwrite: ; write memreg to counter at address
    mov C8200, _std_mem_cmemreg
_std_mem_cread:  ; write counter at address to memreg 
    mov _std_mem_cmemreg, C8200
_std_mem_twrite: ; write memreg to timer at address
    mov T8200, _std_mem_tmemreg
_std_mem_tread:  ; write timer at address to memreg
    mov _std_mem_tmemreg, T8200