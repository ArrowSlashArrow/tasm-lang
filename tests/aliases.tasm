; This program uses all available aliases and a user-defined alias.
_init:
    LMALLOC 10
    ALIAS custom_alias, g123
    ALIAS rtn, routine

routine:
    ADD C1, C2

_start:
    MOV MEMREG, PTRPOS
    MOV POINTS, ATTEMPTS
    MOV T1, MEMSIZE
    ADD T1, MAINTIME
    SPAWN custom_alias
    SPAWN rtn