_init:
    LMALLOC 48
    INITMEM 123323, 3243234, 1656, 86789, 678, 65478, 53467, 3456, 3452, 41, 23, 1243, 1234, 25, 346, 345, 688745, 512, 34, 1235, 315
    DISPLAY C1
    DISPLAY MEMREG
    DISPLAY PTRPOS

add:
    LMFUNC
    ADD C1, MEMREG
    LMPTR 1
    FL add, put_sum, PTRPOS, 32

put_sum:
    LMWRITE
    MOV MEMREG, C1
    LMFUNC

_start:
    LMREAD
    SPAWN add
    
